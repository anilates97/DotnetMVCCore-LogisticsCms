@model List<ResultAboutDto>

<!-- About -->
<section class="about-section" id="about">
  <div class="container">
    <div class="about-grid">
      <div class="about-image-wrapper">
        <div class="about-image-main">
          <img src="/templates/assets/imgs/page/homepage1/img1.png" alt="LojiS depo operasyonu" loading="lazy">
        </div>
        <div class="about-accent-box">
          <span>10+</span>
        </div>
      </div>

      <div class="about-content">
        <span class="section-badge" data-nav-trigger>Hakkımızda</span>
        @foreach (var about in Model)
        {
          <h2 class="about-title">@about.Title</h2>
          <p class="about-desc">@about.Description</p>
        }

        <ul class="about-features">
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Süreç Takibi
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Operasyon Planlaması
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Süreç Görünürlüğü
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Dosya Paylaşımı ve İletişim
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Terminlere Zamanında Uyum
          </li>
          <li>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
            Proje Bazlı Zaman Yönetimi
          </li>
        </ul>

        <a href="#contact" class="btn-primary">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          Daha Fazla Bilgi
        </a>
      </div>
    </div>
  </div>
</section>
