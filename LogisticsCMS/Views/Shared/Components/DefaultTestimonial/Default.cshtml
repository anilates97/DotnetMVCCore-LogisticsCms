@model List<LogisticsCMS.Dtos.Testimonial.ResultTestimonialDto>

@if (Model != null && Model.Any())
{
  <section class="testimonials-section section-padding" id="testimonial">
    <div class="container">
      <div class="text-center">
        <span class="section-badge">Müşteri Yorumları</span>
        <h2 class="section-title">Müşterilerimiz Ne Diyor?</h2>
        <p class="section-subtitle">Taşımacılık çözümlerimizi deneyimleyen müşterilerimizin görüşleri.</p>
      </div>

      <div class="testimonials-grid stagger">
        @foreach (var testimonial in Model)
        {
          <div class="testimonial-card">
            <div class="testimonial-author">
              <img src="@testimonial.ImageUrl" alt="@testimonial.NameSurname" loading="lazy">
              <div>
                <div class="testimonial-name">@testimonial.NameSurname</div>
                <div class="testimonial-title">@testimonial.Title</div>
              </div>
            </div>
            <p>"@testimonial.ReviewDetails"</p>
            <div class="testimonial-rating">
              <div class="testimonial-stars">
                @for (var i = 0; i < testimonial.ReviewScore; i++)
                {
                  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
                }
              </div>
              <span class="testimonial-rate">@testimonial.ReviewScore / 5</span>
            </div>
          </div>
        }
      </div>
    </div>
  </section>
}
