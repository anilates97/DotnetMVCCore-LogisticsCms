@model LogisticsCMS.Dtos.GetInTouchSectionDtos.ResultGetInTouchSectionDto

@if (Model is not null)
{
    <section class="section mt-55 bg-1 position-relative pt-90 pb-90">
        <div class="container">
            <div class="row">
                <div class="col-lg-6">
                    <span class="btn btn-tag">Get in touch</span>
                    <h3 class="color-grey-900 mb-20 mt-15">@Model.MainTitle</h3>
                    <p class="font-md color-grey-900 mb-40">@Model.Description</p>
                    <div class="row">
                        <div class="col-lg-6 mb-30">
                            <h6 class="chart-title font-md-bold color-grey-900">@Model.Feature1Title</h6>
                            <p class="font-xs color-grey-900">@Model.Feature1Description</p>
                        </div>
                        <div class="col-lg-6 mb-30">
                            <h6 class="feature-title font-md-bold color-grey-900">@Model.Feature2Title</h6>
                            <p class="font-xs color-grey-900">@Model.Feature2Description</p>
                        </div>
                    </div>
                    <div class="mt-20">
                        <a class="btn btn-brand-2 mr-20" href="contact.html">Contact Us</a>
                        <a class="btn btn-link-medium" href="#">
                            Learn More
                            <svg class="w-6 h-6 icon-16 ml-5" fill="none" stroke="currentColor" viewbox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>
        </div>
        <div class="box-image-touch" style="background-image:url('@Model.ImageUrl')"></div>
    </section>
}

