@model LogisticsCMS.Dtos.GetInTouchSection.ResultGetInTouchSectionDto

<!-- Get In Touch (Highlight CTA) -->
@if (Model is not null)
{
  <section class="touch-section">
    <div class="container">
      <div class="touch-inner">
        <div class="touch-content">
          <span class="section-badge touch-badge">İletişim</span>

          <div class="touch-copy">
            <h2>@Model.MainTitle</h2>
            <p>@Model.Description</p>
          </div>

          <div class="touch-features">
            <article class="touch-feature">
              <div class="touch-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M3 17l6-6 4 4 8-8" />
                  <path d="M14 7h7v7" />
                </svg>
              </div>
              <div class="touch-feature-body">
                <h6>@Model.Feature1Title</h6>
                <p>@Model.Feature1Description</p>
              </div>
            </article>

            <article class="touch-feature">
              <div class="touch-feature-icon">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3l7 4v5c0 5-3.5 8-7 9-3.5-1-7-4-7-9V7l7-4Z" />
                  <path d="m9.5 12 1.8 1.8L15 10.2" />
                </svg>
              </div>
              <div class="touch-feature-body">
                <h6>@Model.Feature2Title</h6>
                <p>@Model.Feature2Description</p>
              </div>
            </article>
          </div>

          <div class="touch-actions">
            <a class="btn-primary" href="#contact">Bize Ulaşın</a>
            <a class="btn-outline-white" href="#about">
              Daha Fazla Bilgi
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
          </div>
        </div>

        <div class="touch-visual">
          <div class="touch-visual-orb touch-visual-orb-a"></div>
          <div class="touch-visual-orb touch-visual-orb-b"></div>

          <div class="touch-image-card">
            <div class="touch-image-meta">
              <span class="touch-image-pill">Operasyon Akışı</span>
              <span class="touch-image-pill touch-image-pill-alt">7/24 Takip</span>
            </div>
            <div class="touch-image">
              <img src="@Model.ImageUrl" alt="@Model.MainTitle" loading="lazy">
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
}
