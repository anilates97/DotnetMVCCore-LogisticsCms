<!-- Header -->
<header class="site-header" id="siteHeader">
  <div class="header-inner">
    <a class="header-logo" asp-controller="Default" asp-action="Index">
      <svg viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <rect width="36" height="36" rx="8" fill="#0ea5a1" />
        <path d="M10 26V14l8-6 8 6v12H10z" fill="#0f2b4a" stroke="#0f2b4a" stroke-width="1.5" />
        <path d="M16 26v-6h4v6" stroke="#fff" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      LojiS
    </a>

    <nav>
      <ul class="main-nav">
        <li><a href="#top" data-nav-link="top">Ana Sayfa</a></li>
        
        <li class="has-mega">
          <a href="#services" data-nav-link="services">Hizmetler</a>
          <div class="mega-dropdown">
            <div class="mega-group">
              <h6>Deniz Taşımacılığı</h6>
              <ul class="megamenu">
                <li><span class="menu-text">Konteyner Taşımacılığı</span></li>
                <li><span class="menu-text">Dökme Yük Taşımacılığı</span></li>
                <li><span class="menu-text">Ro-Ro Taşımacılığı</span></li>
                <li><span class="menu-text">Parça Yük Taşımacılığı</span></li>
              </ul>
            </div>
            <div class="mega-group">
              <h6>Hava Taşımacılığı</h6>
              <ul class="megamenu">
                <li><span class="menu-text">Genel Kargo</span></li>
                <li><span class="menu-text">Ekspres Taşımacılık</span></li>
                <li><span class="menu-text">Tehlikeli Madde Taşımacılığı</span></li>
                <li><span class="menu-text">Gabari Dışı Yük</span></li>
              </ul>
            </div>
            <div class="mega-group">
              <h6>Kara Yolu ve Depolama</h6>
              <ul class="megamenu">
                <li><span class="menu-text">Kara Yolu Yük Taşımacılığı</span></li>
                <li><span class="menu-text">İntermodal Taşımacılık</span></li>
                <li><span class="menu-text">E-Ticaret Operasyonları</span></li>
                <li><span class="menu-text">Depolama Çözümleri</span></li>
              </ul>
            </div>
          </div>
        </li>
        <li><a href="#about" data-nav-link="about">Hakkımızda</a></li>
        <li><a href="#contact" data-nav-link="contact">İletişim</a></li>
      </ul>
    </nav>

    <div class="header-actions">
      <a class="btn-nav-login" asp-controller="Account" asp-action="Login">Giriş</a>
      <a class="btn-nav-track" asp-controller="Tracking" asp-action="Index">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 16v3a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2h3" /><rect x="2" y="6" width="20" height="14" rx="2" /><path d="M10 10h4m-4 4h4" /><path d="M16 2v4M16 2H12M16 2h4" /></svg>
        Kargo Takip
      </a>
    </div>

    <button class="mobile-toggle" id="mobileToggle" aria-label="Menü">
      <span></span><span></span><span></span>
    </button>
  </div>
</header>

<!-- Mobile Nav -->
<div class="mobile-nav" id="mobileNav">
  <div class="container">
    <ul>
      <li><a href="#top" data-nav-link="top">Ana Sayfa</a></li>
      <li><a href="#about" data-nav-link="about">Hakkımızda</a></li>
      <li><a href="#services" data-nav-link="services">Hizmetler</a></li>
      <li><a asp-controller="Tracking" asp-action="Index">Kargo Takip</a></li>
      <li><a href="#faq">SSS</a></li>
      <li><a href="#contact" data-nav-link="contact">İletişim</a></li>
      <li><a asp-controller="Account" asp-action="Login">Giriş Yap</a></li>
    </ul>
    <div class="mobile-nav-actions">
      <a class="btn-primary" asp-controller="Tracking" asp-action="Index">Kargo Takip</a>
    </div>
  </div>
</div>

<script>
  const header = document.getElementById('siteHeader');
  const mobileToggle = document.getElementById('mobileToggle');
  const mobileNav = document.getElementById('mobileNav');
  const sectionIds = ['top', 'about', 'services', 'contact'];
  const navLinks = Array.from(document.querySelectorAll('[data-nav-link]'));
  let pendingTargetId = null;
  let currentActiveSectionId = 'top';
  let isProgrammaticScroll = false;
  let programmaticScrollTimeoutId = null;

  function updateHeaderState() {
    if (header) {
      header.classList.toggle('scrolled', window.scrollY > 20);
    }
  }

  function closeMobileNav() {
    mobileToggle.classList.remove('active');
    mobileNav.classList.remove('open');
    document.body.style.overflow = '';
  }

  function setActiveLink(sectionId) {
    currentActiveSectionId = sectionId;
    navLinks.forEach(link => {
      link.classList.toggle('active', link.dataset.navLink === sectionId);
    });
  }

  function getScrollOffset() {
    return (header ? header.offsetHeight : 0) + 120;
  }

  function releasePendingNavigation() {
    pendingTargetId = null;
    isProgrammaticScroll = false;

    if (programmaticScrollTimeoutId) {
      window.clearTimeout(programmaticScrollTimeoutId);
      programmaticScrollTimeoutId = null;
    }
  }

  function resolveActiveSection() {
    const sections = sectionIds
      .map(id => document.getElementById(id))
      .filter(Boolean)
      .sort((a, b) => a.offsetTop - b.offsetTop);

    if (sections.length === 0) {
      setActiveLink('top');
      return;
    }

    const offset = getScrollOffset();
    const viewportHeight = window.innerHeight || document.documentElement.clientHeight;

    if (pendingTargetId) {
      const pendingSection = document.getElementById(pendingTargetId);

      if (pendingSection) {
        const pendingTrigger = pendingSection.querySelector('[data-nav-trigger]') || pendingSection;
        const pendingRect = pendingTrigger.getBoundingClientRect();
        const targetReached = pendingRect.top >= offset && pendingRect.top <= Math.max(offset + 24, viewportHeight * 0.45);

        if (!targetReached) {
          setActiveLink(pendingTargetId);
          return;
        }
      }

      pendingTargetId = null;
    }

    const visibleTriggeredSection = sections.find(section => {
      const trigger = section.querySelector('[data-nav-trigger]') || section;
      const rect = trigger.getBoundingClientRect();
      return rect.top >= offset && rect.top <= viewportHeight - 80;
    });

    if (visibleTriggeredSection) {
      setActiveLink(visibleTriggeredSection.id);
      return;
    }

    if (window.scrollY <= 16 && currentActiveSectionId !== 'top') {
      setActiveLink('top');
    }
  }

  updateHeaderState();
  resolveActiveSection();

  window.addEventListener('scroll', () => {
    updateHeaderState();
    resolveActiveSection();
  }, { passive: true });

  window.addEventListener('resize', resolveActiveSection);

  ['wheel', 'touchstart'].forEach(eventName => {
    window.addEventListener(eventName, () => {
      if (isProgrammaticScroll) {
        releasePendingNavigation();
        resolveActiveSection();
      }
    }, { passive: true });
  });

  window.addEventListener('keydown', event => {
    const scrollKeys = ['ArrowUp', 'ArrowDown', 'PageUp', 'PageDown', 'Home', 'End', 'Space'];
    if (isProgrammaticScroll && scrollKeys.includes(event.code)) {
      releasePendingNavigation();
      resolveActiveSection();
    }
  });

  if (mobileToggle && mobileNav) {
    mobileToggle.addEventListener('click', () => {
      mobileToggle.classList.toggle('active');
      mobileNav.classList.toggle('open');
      document.body.style.overflow = mobileNav.classList.contains('open') ? 'hidden' : '';
    });

    mobileNav.querySelectorAll('a').forEach(link => {
      link.addEventListener('click', closeMobileNav);
    });
  }

  navLinks.forEach(link => {
    link.addEventListener('click', () => {
      const targetId = link.dataset.navLink;
      if (targetId) {
        isProgrammaticScroll = true;
        pendingTargetId = targetId;
        setActiveLink(targetId);

        if (programmaticScrollTimeoutId) {
          window.clearTimeout(programmaticScrollTimeoutId);
        }

        programmaticScrollTimeoutId = window.setTimeout(() => {
          releasePendingNavigation();
          resolveActiveSection();
        }, 1200);
      }
    });
  });
</script>
