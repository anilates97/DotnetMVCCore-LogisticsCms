<!-- Statistics -->
<section class="stats-section" id="stats">
  <div class="container">
    <div class="text-center" style="margin-bottom:48px;">
      <span class="section-badge" style="background:rgba(255,255,255,.08);color:rgba(255,255,255,.9);">Rakamlarla Biz</span>
      <h2 class="section-title text-white">Lojistikte Güçlü Sonuçlar ve Sürdürülebilir Büyüme</h2>
      <p class="section-subtitle" style="color:rgba(255,255,255,.6);">Operasyonel verilerimizi şeffaf biçimde sunuyoruz.</p>
    </div>

    <div class="stats-grid stagger">
      <div class="stat-card">
        <h3>+ @ViewBag.v1</h3>
        <p>Toplam Kargo Sayısı</p>
      </div>
      <div class="stat-card">
        <h3>+ @ViewBag.v2</h3>
        <p>Teslim Edilen Gönderi</p>
      </div>
      <div class="stat-card">
        <h3>+ @ViewBag.v3</h3>
        <p>Şehir</p>
      </div>
      <div class="stat-card">
        <h3>+ @ViewBag.v4</h3>
        <p>Dağıtımdaki Gönderiler</p>
      </div>
    </div>
  </div>
</section>
