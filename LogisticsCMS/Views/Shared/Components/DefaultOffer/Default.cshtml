@model IEnumerable<ResultOfferDto>

<!-- Services / Offers -->
<section class="services-section section-padding" id="services">
  <div class="container">
    <div class="text-center">
      <span class="section-badge" data-nav-trigger>Hizmetlerimiz</span>
      <h2 class="section-title">Lojistik İhtiyaçlarınız İçin Bütünsel Çözümler</h2>
      <p class="section-subtitle">Deniz, hava, kara ve demir yolu taşımacılığında güvenilir, hızlı ve esnek çözümler sunuyoruz. Süreçlerinizi baştan sona profesyonel şekilde yönetiyoruz.</p>
    </div>

    <div class="services-grid stagger">
      @if (Model != null && Model.Any())
      {
        @foreach (var offer in Model.Where(o => o.IsStatus))
        {
          <div class="service-card">
            <div class="service-card-img">
              <img src="@offer.ImageUrl" alt="@offer.Title" loading="lazy">
            </div>
            <div class="service-card-body">
              <h5>@offer.Title</h5>
              <p>@offer.Description</p>
            </div>
          </div>
        }
      }
      else
      {
        <div class="empty-state" style="grid-column:1/-1;">
          <div class="empty-state-icon">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/></svg>
          </div>
          <h3>Henüz Hizmet Eklenmedi</h3>
          <p>Yönetim panelinden hizmetlerinizi ekleyerek burada görünmesini sağlayabilirsiniz.</p>
        </div>
      }
    </div>
  </div>
</section>
