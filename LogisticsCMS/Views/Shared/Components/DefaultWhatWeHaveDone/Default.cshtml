@model List<LogisticsCMS.Dtos.ProjectSection.ResultProjectSectionDto>

@if (Model != null && Model.Any())
{
  <section class="projects-section" id="projects">
    <div class="container">
      <div class="text-center">
        <span class="section-badge">Projelerimiz</span>
        <h2 class="section-title">Tamamladığımız Projeler</h2>
        <p class="section-subtitle">Güçlü iş ortaklarımızla birlikte başarıyla tamamladığımız projelere göz atın.</p>
      </div>

      <div class="projects-grid stagger">
        @foreach (var project in Model)
        {
          <article class="project-card">
            <img src="@project.ImageUrl" alt="@project.Title" loading="lazy">
            <div class="project-card-overlay">
              <h5>@project.Title</h5>
              <p>@project.Description</p>
            </div>
          </article>
        }
      </div>
    </div>
  </section>
}
