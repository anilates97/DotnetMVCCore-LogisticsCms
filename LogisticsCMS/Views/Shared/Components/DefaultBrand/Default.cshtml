@model List<ResultBrandDto>

<!-- Brands -->
<section class="brands-section" id="brands">
  <div class="container">
    <div class="brands-inner">
      <span class="brands-label">Güvenilir İş Ortaklarımız</span>
      <div class="brands-slider-shell">
        @if (Model != null && Model.Any())
        {
          <div class="box-swiper">
            <div class="swiper-container brands-swiper">
              <div class="swiper-wrapper">
                @foreach (var brand in Model)
                {
                  <div class="swiper-slide">
                    <a href="#" class="brand-logo-link" aria-label="@brand.BrandName">
                      <img src="@brand.ImageUrl" alt="@brand.BrandName">
                    </a>
                  </div>
                }
              </div>
            </div>
          </div>
        }
        else
        {
          <span class="text-muted font-sm">Henüz marka eklenmedi</span>
        }
      </div>
    </div>
  </div>
</section>
