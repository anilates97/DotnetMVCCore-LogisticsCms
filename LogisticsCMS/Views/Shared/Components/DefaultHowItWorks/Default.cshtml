@model List<LogisticsCMS.Dtos.HowItWork.ResultHowItWorkDto>

@if (Model != null && Model.Any())
{
  var featuredStep = Model.First();

  <section class="how-section section-padding" id="how-it-works">
    <div class="container">
      <div class="text-center">
        <span class="section-badge">Nasıl Çalışır?</span>
        <h2 class="section-title">Sipariş Süreci Adım Adım</h2>
        <p class="section-subtitle">Müşteri ihtiyaçları analiz edilir, taşıma türü belirlenir ve sevkiyat için en uygun operasyon planı hazırlanır.</p>
      </div>

      <div class="how-grid">
        <div class="how-visual-card">
          <div class="how-visual-glow"></div>
          <div class="how-image-main">
            <img src="@featuredStep.ImageUrl" alt="Lojistik operasyon görseli" loading="lazy">
          </div>
          <div class="how-visual-badge">
            <span class="how-visual-badge-label">Operasyon Akışı</span>
            <strong>Planlama, hazırlık ve teslimat tek akışta yönetilir</strong>
          </div>
        </div>

        <ul class="how-steps stagger">
          @foreach (var step in Model)
          {
            <li class="how-step">
              <div class="how-step-img">
                <img src="@step.ImageUrl" alt="@step.Title" loading="lazy">
              </div>
              <div class="how-step-body">
                <h5>@step.Title</h5>
                <p>@step.Description</p>
              </div>
            </li>
          }
        </ul>
      </div>
    </div>
  </section>
}
