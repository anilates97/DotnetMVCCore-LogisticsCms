@model ErrorViewModel
@{
    ViewData["Title"] = "Hata";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card border-0 shadow-sm">
                <div class="card-body p-5">
                    <div class="mb-4">
                        <span class="badge text-bg-danger px-3 py-2">
                            Hata @(Model.StatusCode.HasValue ? $"- {Model.StatusCode}" : string.Empty)
                        </span>
                    </div>

                    <h1 class="h2 mb-3">Bir sorun oluştu</h1>
                    <p class="text-muted mb-4">@Model.UserMessage</p>

                    @if (!string.IsNullOrWhiteSpace(Model.Path))
                    {
                        <p class="mb-2">
                            <strong>Yol:</strong> <code>@Model.Path</code>
                        </p>
                    }

                    @if (Model.ShowRequestId)
                    {
                        <p class="mb-4">
                            <strong>Talep No:</strong> <code>@Model.RequestId</code>
                        </p>
                    }

                    <div class="d-flex gap-2 flex-wrap">
                        <a asp-controller="Home" asp-action="Index" class="btn btn-primary">Ana sayfaya don</a>
                        <button type="button" class="btn btn-outline-secondary" onclick="window.history.back()">Onceki sayfaya git</button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
