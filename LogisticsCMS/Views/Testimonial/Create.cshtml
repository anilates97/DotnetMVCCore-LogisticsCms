@model CreateTestimonialDto
@{
    ViewData["Title"] = "CreateTestimonial";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Testimonial/Create.css" asp-append-version="true" />
}


<div class="testimonial-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-ornament">
            <div class="ornament-line"></div>
            <div class="ornament-diamond"></div>
            <div class="ornament-line"></div>
        </div>
        <h1 class="page-title">
            <span class="title-accent">Müşteri</span> Yorumu Ekle
        </h1>
        <p class="page-subtitle">
            Değerli müşterilerinizin görüşlerini ve deneyimlerini paylaşın
        </p>
    </div>

    <!-- Split Layout -->
    <form method="post" id="testimonialForm" asp-controller="Testimonial" asp-action="Create">
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <!-- Personal Info Section -->
                <div class="form-section">
                    <h2 class="section-title">Kişisel Bilgiler</h2>

                    <div class="form-row">
                        <div class="form-group">
                            <label class="form-label" asp-for="NameSurname">
                                Ad Soyad <span class="label-required">*</span>
                            </label>
                            <input type="text" 
                                   class="form-input" 
                                   asp-for="NameSurname" 
                                   id="nameInput"
                                   placeholder="Örn: Ahmet Yılmaz"
                                   maxlength="100"
                                   required />
<span asp-validation-for="NameSurname" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label" asp-for="Title">
                                Ünvan <span class="label-required">*</span>
                            </label>
                            <input type="text" 
                                   class="form-input" 
                                   asp-for="Title" 
                                   id="titleInput"
                                   placeholder="Örn: CEO, Müşteri"
                                   maxlength="100"
                                   required />
<span asp-validation-for="Title" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ImageUrl">
                            Fotoğraf URL <span class="label-required">*</span>
                        </label>
                        <input type="text" inputmode="url" 
                               class="form-input" 
                               asp-for="ImageUrl" 
                               id="imageUrlInput"
                               placeholder="https://example.com/photo.jpg"
                               required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                                Profesyonel fotoğraf önerilir
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Review Section -->
                <div class="form-section">
                    <h2 class="section-title">Değerlendirme</h2>

                    <div class="form-group">
                        <label class="form-label" asp-for="ReviewDetails">
                            Yorum Metni <span class="label-required">*</span>
                        </label>
                        <textarea class="form-textarea" 
                                  asp-for="ReviewDetails" 
                                  id="reviewInput"
                                  placeholder="Müşterinizin deneyimini ve görüşlerini buraya yazın..."
                                  maxlength="500"
                                  required></textarea>
<span asp-validation-for="ReviewDetails" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 8h10M7 12h4m1 8l-4-4H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-3l-4 4z" />
                                </svg>
                                Samimi ve içten bir dil kullanın
                            </div>
                            <span class="char-counter">
                                <span id="reviewCounter">0</span>/500
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="rating-wrapper">
                            <div class="rating-label">Puan Değerlendirmesi</div>
                            <div class="stars-container" id="starsContainer">
                                <div class="star" data-value="1">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                    </svg>
                                </div>
                                <div class="star" data-value="2">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                    </svg>
                                </div>
                                <div class="star" data-value="3">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                    </svg>
                                </div>
                                <div class="star" data-value="4">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                    </svg>
                                </div>
                                <div class="star" data-value="5">
                                    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                                    </svg>
                                </div>
                            </div>
                            <input type="hidden" asp-for="ReviewScore" id="reviewScoreInput" value="5" />
<span asp-validation-for="ReviewScore" class="text-danger"></span>
                            <div class="rating-value">
                                Seçili Puan: <strong id="ratingDisplay">5</strong> / 5
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="status-wrapper">
                            <div class="status-label">
                                <h4>Yayın Durumu</h4>
                                <p>Yorumu anında yayınla</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" asp-for="Status" id="statusToggle" checked />
<span asp-validation-for="Status" class="text-danger"></span>
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Luxury Info -->
                <div class="luxury-info">
                    <h3 class="info-title">Premium İpuçları</h3>
                    <ul class="info-list">
                        <li>Gerçek müşteri deneyimlerini paylaşın</li>
                        <li>Profesyonel ve net fotoğraflar kullanın</li>
                        <li>Yorumlar samimi ve içten olmalı</li>
                        <li>Ünvan bilgisi güvenilirlik katar</li>
                    </ul>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-controller="Testimonial" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-label">Canlı Önizleme</div>
                    <div class="testimonial-card">
                        <div class="quote-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M6 17h3l2-4V7H5v6h3zm8 0h3l2-4V7h-6v6h3z"/>
                            </svg>
                        </div>
                        <div class="avatar-preview">
                            <img src="" id="previewAvatar" alt="Preview" />
                            <div class="avatar-placeholder" id="avatarPlaceholder">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                                </svg>
                            </div>
                        </div>
                        <h3 class="preview-name" id="previewName">Ad Soyad</h3>
                        <p class="preview-title" id="previewTitle">Ünvan</p>
                        <div class="preview-stars" id="previewStars">
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                            </svg>
                        </div>
                        <p class="preview-review" id="previewReview">"Yorum metni burada görünecek..."</p>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/Testimonial/Create.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


