@model List<ResultQuestionDto>
@{
    ViewData["Title"] = "Soru Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Question/Index.css" asp-append-version="true" />
}

<div class="question-list-container">
    <div class="page-header">
        <div class="header-left">
            <span class="page-kicker">Sık Sorulan Sorular</span>
            <h1 class="page-title">Soru Listesi</h1>
            <p class="page-subtitle">Tüm soru kayıtlarını tek ekranda görüntüleyin, filtreleyin ve yönetin.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="Question" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Yeni Soru
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <div class="stats-panel">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">Toplam</div>
                <div class="stat-value">@((Model?.Count) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@(Model?.Count(x => x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Pasif</div>
                <div class="stat-value">@(Model?.Count(x => !x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Ortalama Uzunluk</div>
                <div class="stat-value">@(Model != null && Model.Any() ? Math.Round(Model.Average(x => x.Description?.Length ?? 0)) : 0)</div>
            </div>
        </div>
    </div>

    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Soru ara..." />
        </div>
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="questions-grid" id="questionsGrid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var question = Model[i];
                <div class="question-card"
                     data-status="@(question.Status ? "active" : "inactive")"
                     data-title="@question.Title.ToLower()">
                    <div class="card-header">
                        <div class="question-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        <div class="question-number">@((i + 1).ToString())</div>
                    </div>

                    <div class="card-content">
                        <h3 class="question-title">@question.Title</h3>
                        <p class="question-description">@question.Description</p>

                        <div class="card-footer">
                            <div class="meta-info">ID: @question.QuestionId.Substring(0, 8)</div>
                            <div class="status-badge @(question.Status ? "active" : "inactive")">
                                @(question.Status ? "Aktif" : "Pasif")
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-controller="Question" asp-action="Edit" asp-route-id="@question.QuestionId" class="action-btn edit">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Düzenle
                            </a>
                            <a asp-controller="Question" asp-action="Delete" asp-route-id="@question.QuestionId"
                               class="action-btn delete"
                               onclick="return confirm('Bu soruyu silmek istediğinizden emin misiniz?')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.228 9c.549-1.165 2.03-2 3.772-2 2.21 0 4 1.343 4 3 0 1.4-1.278 2.575-3.006 2.907-.542.104-.994.54-.994 1.093m0 3h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <h3 class="empty-title">Henüz Soru Yok</h3>
            <p class="empty-text">Müşterilerinizin sık sorduğu soruları ekleyerek başlayın.</p>
            <a asp-controller="Question" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                İlk Soruyu Ekle
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/views/Question/Index.js" asp-append-version="true"></script>
}
