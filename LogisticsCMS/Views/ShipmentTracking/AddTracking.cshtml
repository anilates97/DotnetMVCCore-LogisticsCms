@model CreateShipmentTrackingDto
@{
    ViewData["Title"] = "Hareket Ekle";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/ShipmentTracking/AddTracking.css" asp-append-version="true" />
}


<div class="page-container">

    <!-- Header -->
    <div class="page-header">
        <div class="breadcrumb">
            <a asp-controller="Dashboard" asp-action="Index"><i class="bi bi-house-door"></i> Ana Sayfa</a>
            <i class="bi bi-chevron-right"></i>
            <a asp-controller="Shipment" asp-action="Index">Gönderiler</a>
            <i class="bi bi-chevron-right"></i>
            <a asp-controller="ShipmentTracking" asp-action="Index" asp-route-trackingNumber="@ViewBag.TrackingNumber">@ViewBag.TrackingNumber</a>
            <i class="bi bi-chevron-right"></i>
            <span>Hareket Ekle</span>
        </div>
        <h1 class="page-title">
            <div class="title-icon"><i class="bi bi-plus-circle"></i></div>
            Yeni Kargo Hareketi Ekle
        </h1>
        <p class="page-subtitle">Kargonun mevcut konumunu ve durumunu güncelleyin</p>
    </div>

    <!-- Banner -->
    <div class="shipment-banner">
        <div>
            <div class="banner-tracking-label">Takip Numarası</div>
            <div class="banner-tracking-number">@ViewBag.TrackingNumber</div>
        </div>
        <div class="banner-divider"></div>
        <div class="banner-info">
            <div class="banner-info-item">
                <span class="banner-info-label">Gönderici</span>
                <span class="banner-info-value">@ViewBag.SenderName</span>
            </div>
            <div class="banner-info-item">
                <span class="banner-info-label">Alıcı</span>
                <span class="banner-info-value">@ViewBag.ReceiverName</span>
            </div>
            <div class="banner-info-item">
                <span class="banner-info-label">Rota</span>
                <span class="banner-info-value">@ViewBag.OriginCity → @ViewBag.DestinationCity</span>
            </div>
        </div>
        <div class="banner-status">
            <div class="banner-status-badge">
                <i class="bi bi-circle-fill" style="font-size:8px;"></i>
                @ViewBag.CurrentStatus
            </div>
        </div>
    </div>

    <!-- Form -->
    <form asp-action="AddTracking" asp-controller="ShipmentTracking" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="TrackingNumber" />

        <div class="main-grid">
            <div class="form-column">

                <!-- 1: Tarih & Lokasyon -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">1</div>
                        <div class="section-title">Tarih ve Lokasyon</div>
                    </div>
                    <div class="form-grid">
                        <div>
                            <label class="form-label">
                                <i class="bi bi-calendar-event label-icon"></i>
                                Hareket Tarihi <span class="label-required">*</span>
                            </label>
                            <input type="datetime-local" class="form-input" asp-for="EventDate" id="eventDateInput" required />
                            <span asp-validation-for="EventDate" class="input-hint" style="color:var(--danger);"></span>
                        </div>
                        <div>
                            <label class="form-label">
                                <i class="bi bi-geo-alt label-icon"></i>
                                Lokasyon <span class="label-required">*</span>
                            </label>
                            <input type="text" class="form-input" asp-for="Location" id="locationInput" placeholder="Örn: İstanbul / Kadıköy Şubesi" maxlength="150" required />
                            <span asp-validation-for="Location" class="input-hint" style="color:var(--danger);"></span>
                        </div>
                    </div>
                </div>

                <!-- 2: Durum -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">2</div>
                        <div class="section-title">Kargo Durumu</div>
                    </div>
                    <input type="hidden" asp-for="TrackingStatus" id="trackingStatusInput" />
                    <div class="status-grid">
                        <label class="status-card" data-status="Gönderi Alındı" onclick="selectStatus(this)">
                            <input type="radio" name="statusRadio" value="Gönderi Alındı" />
                            <div class="status-icon"><i class="bi bi-box-seam"></i></div>
                            <div class="status-text">
                                <div class="status-name">Gönderi Alındı</div>
                                <div class="status-desc">Şubede teslim alındı</div>
                            </div>
                            <div class="status-check"><i class="bi bi-check"></i></div>
                        </label>
                        <label class="status-card" data-status="Transfer Merkezinde" onclick="selectStatus(this)">
                            <input type="radio" name="statusRadio" value="Transfer Merkezinde" />
                            <div class="status-icon"><i class="bi bi-building"></i></div>
                            <div class="status-text">
                                <div class="status-name">Transfer Merkezinde</div>
                                <div class="status-desc">Transfer noktasında</div>
                            </div>
                            <div class="status-check"><i class="bi bi-check"></i></div>
                        </label>
                        <label class="status-card" data-status="Yolda" onclick="selectStatus(this)">
                            <input type="radio" name="statusRadio" value="Yolda" />
                            <div class="status-icon"><i class="bi bi-truck"></i></div>
                            <div class="status-text">
                                <div class="status-name">Yolda</div>
                                <div class="status-desc">Taşıma aracında</div>
                            </div>
                            <div class="status-check"><i class="bi bi-check"></i></div>
                        </label>
                        <label class="status-card" data-status="Dağıtımda" onclick="selectStatus(this)">
                            <input type="radio" name="statusRadio" value="Dağıtımda" />
                            <div class="status-icon"><i class="bi bi-bicycle"></i></div>
                            <div class="status-text">
                                <div class="status-name">Dağıtımda</div>
                                <div class="status-desc">Kurye teslimatta</div>
                            </div>
                            <div class="status-check"><i class="bi bi-check"></i></div>
                        </label>
                        <label class="status-card" data-status="Teslim Edildi" onclick="selectStatus(this)" style="grid-column: 1 / -1;">
                            <input type="radio" name="statusRadio" value="Teslim Edildi" />
                            <div class="status-icon"><i class="bi bi-check-circle"></i></div>
                            <div class="status-text">
                                <div class="status-name">Teslim Edildi</div>
                                <div class="status-desc">Alıcıya başarıyla teslim edildi</div>
                            </div>
                            <div class="status-check"><i class="bi bi-check"></i></div>
                        </label>
                    </div>
                </div>

                <!-- 3: A??klama -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">3</div>
                        <div class="section-title">Hareket A??klamas?</div>
                    </div>
                    <div class="form-grid full">
                        <div>
                            <label class="form-label">
                                <i class="bi bi-card-text label-icon"></i>
                                A??klama <span class="label-required">*</span>
                            </label>
                            <textarea class="form-textarea" asp-for="Description" id="descriptionInput" rows="4" placeholder="?rn: Kargonuz transfer merkezine ula?t?..." maxlength="300" required></textarea>
                            <span asp-validation-for="Description" class="input-hint" style="color:var(--danger);"></span>
                            <div class="input-hint">
                                <i class="bi bi-info-circle"></i>
                                <span id="descCounter">0</span>/300 karakter
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-action="Index" asp-controller="ShipmentTracking" asp-route-trackingNumber="@ViewBag.TrackingNumber" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i> ?ptal
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-plus-circle"></i> Hareketi Kaydet
                    </button>
                </div>

            </div>

            <!-- Preview -->
            <div class="preview-column">
                <div class="preview-card">
                    <div class="preview-card-header">
                        <i class="bi bi-clock-history"></i>
                        <span>Canl? ?nizleme</span>
                    </div>
                    <div class="preview-card-body">
                        <div class="tl-wrap">

                            <!-- Yeni hareket -->
                            <div class="tl-item">
                                <div class="tl-left">
                                    <div class="tl-dot new-event" id="previewDot">
                                        <i class="bi bi-plus" id="previewDotIcon"></i>
                                    </div>
                                    <div class="tl-line"></div>
                                </div>
                                <div class="tl-content new-content">
                                    <div class="tl-new-label"><i class="bi bi-stars"></i> Yeni Hareket</div>
                                    <div class="tl-badge" id="previewBadge" style="background:rgba(10,77,104,0.1); color:var(--primary);">
                                        <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                                        <span id="previewStatusText">Durum se?iniz...</span>
                                    </div>
                                    <div class="tl-location" id="previewLocation" style="color:#94a3b8;">Lokasyon giriniz...</div>
                                    <div class="tl-desc" id="previewDesc">A??klama giriniz...</div>
                                    <div class="tl-date" id="previewDate">--.--.---- --:--</div>
                                </div>
                            </div>

                            <!-- Mevcut hareketler -->
                            @if (ViewBag.ExistingTrackings != null)
                            {
                                foreach (var t in ViewBag.ExistingTrackings)
                                {
                                    <div class="tl-item">
                                        <div class="tl-left">
                                            <div class="tl-dot old-event"><i class="bi bi-check"></i></div>
                                            <div class="tl-line"></div>
                                        </div>
                                        <div class="tl-content">
                                            <div class="tl-badge" style="background:var(--light); color:#64748b;">
                                                <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                                                @t.TrackingStatus
                                            </div>
                                            <div class="tl-location">@t.Location</div>
                                            <div class="tl-desc">@t.Description</div>
                                            <div class="tl-date">@((DateTime)t.EventDate).ToString("dd.MM.yyyy HH:mm")</div>
                                        </div>
                                    </div>
                                }
                            }

                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/ShipmentTracking/AddTracking.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


