@model List<ResultShipmentTrackingDto>
@{
    ViewData["Title"] = "Kargo Hareketleri";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/ShipmentTracking/Index.css" asp-append-version="true" />
}


@{
    string GetDotClass(string status) => status switch
    {
        "Gönderi Alındı"      => "received",
        "Transfer Merkezinde" => "transfer",
        "Yolda"               => "transit",
        "Dağıtımda"           => "delivery",
        "Teslim Edildi"       => "delivered",
        _                     => "transit"
    };

    string GetStatusIcon(string status) => status switch
    {
        "Gönderi Alındı"      => "bi-box-seam",
        "Transfer Merkezinde" => "bi-building",
        "Yolda"               => "bi-truck",
        "Dağıtımda"           => "bi-bicycle",
        "Teslim Edildi"       => "bi-check-circle-fill",
        _                     => "bi-circle"
    };

    var statuses = new[]
    {
        ("Gönderi Alındı",      "#8b5cf6"),
        ("Transfer Merkezinde", "#3b82f6"),
        ("Yolda",               "#088395"),
        ("Dağıtımda",           "#f59e0b"),
        ("Teslim Edildi",       "#16a34a")
    };
}

<div class="page-container">

    <!-- Header -->
    <div class="page-header">
        <div>
            <div class="breadcrumb">
                <a asp-controller="Dashboard" asp-action="Index">
                    <i class="bi bi-house-door"></i> Ana Sayfa
                </a>
                <i class="bi bi-chevron-right"></i>
                <a asp-controller="Shipment" asp-action="Index">Gönderiler</a>
                <i class="bi bi-chevron-right"></i>
                <span>@ViewBag.TrackingNumber — Hareketler</span>
            </div>
            <h1 class="page-title">
                <div class="title-icon"><i class="bi bi-clock-history"></i></div>
                Kargo Hareketleri
            </h1>
            <p class="page-subtitle">
                <span style="font-family:'JetBrains Mono',monospace; font-weight:700; color:var(--primary);">
                    @ViewBag.TrackingNumber
                </span>
                numaral? kargonun hareket ge?mi?i
            </p>
        </div>
        <div class="header-actions">
            <a asp-controller="Shipment" asp-action="Index" class="btn btn-outline">
                <i class="bi bi-arrow-left"></i> Geri D?n
            </a>
            <a asp-controller="ShipmentTracking"
               asp-action="AddTracking"
               asp-route-trackingNumber="@ViewBag.TrackingNumber"
               class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Hareket Ekle
            </a>
        </div>
    </div>

    <!-- Banner -->
    <div class="shipment-banner">
        <div>
            <div class="banner-tracking-label">Takip Numarası</div>
            <div class="banner-tracking-number">@ViewBag.TrackingNumber</div>
        </div>
        <div class="banner-divider"></div>
        <div class="banner-info">
            <div class="banner-info-item">
                <span class="banner-info-label">Gönderici</span>
                <span class="banner-info-value">@ViewBag.SenderName</span>
            </div>
            <div class="banner-info-item">
                <span class="banner-info-label">Alıcı</span>
                <span class="banner-info-value">@ViewBag.ReceiverName</span>
            </div>
            <div class="banner-info-item">
                <span class="banner-info-label">Rota</span>
                <span class="banner-info-value">@ViewBag.OriginCity → @ViewBag.DestinationCity</span>
            </div>
        </div>
        <div class="banner-status">
            <div class="banner-status-badge">
                <div class="banner-status-dot"></div>
                @ViewBag.CurrentStatus
            </div>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-row">
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(10,77,104,0.1); color:var(--primary);">
                <i class="bi bi-list-ul"></i>
            </div>
            <div>
                <div class="stat-label">Toplam Hareket</div>
                <div class="stat-value">@Model.Count</div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(22,163,74,0.1); color:var(--success);">
                <i class="bi bi-check-circle"></i>
            </div>
            <div>
                <div class="stat-label">Son Durum</div>
                <div class="stat-value" style="font-size:13px; font-family:'Poppins',sans-serif; font-weight:700;">
                    @(Model.Any() ? Model.First().TrackingStatus : "-")
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(253,176,34,0.1); color:var(--secondary);">
                <i class="bi bi-calendar-event"></i>
            </div>
            <div>
                <div class="stat-label">?lk Hareket</div>
                <div class="stat-value" style="font-size:14px;">
                    @(Model.Any() ? Model.Last().EventDate.ToString("dd.MM.yyyy") : "-")
                </div>
            </div>
        </div>
        <div class="stat-card">
            <div class="stat-icon" style="background:rgba(59,130,246,0.1); color:var(--info);">
                <i class="bi bi-clock"></i>
            </div>
            <div>
                <div class="stat-label">Son G?ncelleme</div>
                <div class="stat-value" style="font-size:14px;">
                    @(Model.Any() ? Model.First().EventDate.ToString("dd.MM.yyyy") : "-")
                </div>
            </div>
        </div>
    </div>

    <!-- Main Grid -->
    <div class="main-grid">

        <!-- Timeline -->
        <div class="timeline-card">
            <div class="card-header">
                <div class="card-header-left">
                    <i class="bi bi-clock-history" style="color:var(--primary);"></i>
                    <span class="card-header-title">Hareket Ge?mi?i</span>
                    <span class="card-header-count">@Model.Count</span>
                </div>
            </div>
            <div class="card-body">
                @if (Model != null && Model.Any())
                {
                    <div class="timeline">
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var t        = Model[i];
                            var dotClass = GetDotClass(t.TrackingStatus);
                            var icon     = GetStatusIcon(t.TrackingStatus);

                            <div class="tl-item">
                                <div class="tl-left">
                                    <div class="tl-dot dot-@dotClass">
                                        <i class="bi @icon"></i>
                                    </div>
                                    <div class="tl-line"></div>
                                </div>
                                <div class="tl-content">
                                    @if (i == 0)
                                    {
                                        <div class="tl-latest-badge">En Son</div>
                                    }
                                    <div class="tl-content-top">
                                        <span class="tl-badge badge-@dotClass">
                                            <i class="bi bi-circle-fill" style="font-size:6px;"></i>
                                            @t.TrackingStatus
                                        </span>
                                        <div class="tl-actions">
                                            <a asp-controller="ShipmentTracking"
                                               asp-action="UpdateTracking"
                                               asp-route-trackingNumber="@ViewBag.TrackingNumber"
                                               asp-route-index="@(Model.Count - 1 - i)"
                                               class="tl-action-btn edit"
                                               data-tooltip="D?zenle">
                                                <i class="bi bi-pencil-fill"></i>
                                            </a>
                                            <a asp-controller="ShipmentTracking"
                                               asp-action="DeleteTracking"
                                               asp-route-trackingNumber="@ViewBag.TrackingNumber"
                                               asp-route-index="@(Model.Count - 1 - i)"
                                               class="tl-action-btn delete"
                                               data-tooltip="Sil"
                                               onclick="return confirm('Bu hareketi silmek istediğinizden emin misiniz?')">
                                                <i class="bi bi-trash-fill"></i>
                                            </a>
                                        </div>
                                    </div>
                                    <div class="tl-location">
                                        <i class="bi bi-geo-alt-fill"></i>
                                        @t.Location
                                    </div>
                                    <div class="tl-desc">@t.Description</div>
                                    <div class="tl-date">
                                        <i class="bi bi-calendar3"></i>
                                        @t.EventDate.ToString("dd.MM.yyyy HH:mm")
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
                else
                {
                    <div class="empty-state">
                        <div class="empty-icon"><i class="bi bi-inbox"></i></div>
                        <h3 class="empty-title">Hen?z Hareket Yok</h3>
                        <p class="empty-text">Bu kargo i?in hen?z hareket kayd? bulunmuyor.</p>
                        <a asp-controller="ShipmentTracking"
                           asp-action="AddTracking"
                           asp-route-trackingNumber="@ViewBag.TrackingNumber"
                           class="btn btn-primary">
                            <i class="bi bi-plus-circle"></i> ?lk Hareketi Ekle
                        </a>
                    </div>
                }
            </div>
        </div>

        <!-- Side -->
        <div class="side-column">
            <div class="side-card">
                <div class="side-card-header">
                    <i class="bi bi-pie-chart"></i> Durum ?zeti
                </div>
                <div class="side-card-body">
                    <div class="status-summary">
                        @foreach (var (statusName, color) in statuses)
                        {
                            var count = Model?.Count(x => x.TrackingStatus == statusName);
                            <div class="status-summary-item">
                                <div class="status-summary-left">
                                    <div class="status-dot-sm" style="background:@color;"></div>
                                    <span class="status-summary-name">@statusName</span>
                                </div>
                                <span class="status-summary-count">@count</span>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>

    </div>
</div>

