@model UpdateOfferDto
@{
    ViewData["Title"] = "Update Offer";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Offer/Edit.css" asp-append-version="true" />
}


<div class="offer-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-badge">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
            </svg>
            Hizmet Güncelle
        </div>
        <h1 class="page-title">
            <span>Lojistik</span> Hizmeti Güncelle
        </h1>
        <p class="page-subtitle">
            Müşterilerinize sunduğunuz lojistik hizmetlerini ekleyin ve yönetin
        </p>
    </div>

    <!-- Form Layout -->
    <form method="post" id="offerForm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="OfferId" />
<span asp-validation-for="OfferId" class="text-danger"></span>
        <div class="form-layout">
            <!-- Main Form -->
            <div class="form-card">
                <h2 class="section-title">
                    <div class="section-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                        </svg>
                    </div>
                    Hizmet Bilgileri
                </h2>

                <div class="form-group">
                    <label class="form-label" asp-for="Title">
                        <span class="label-icon">T</span>
                        Hizmet Başlığı
                        <span class="required-star">*</span>
                    </label>
                    <input type="text" 
                           class="form-input" 
                           asp-for="Title" 
                           id="titleInput"
                           placeholder="Örn: Sea Forwarding, Kargo Taşımacılığı..."
                           maxlength="100"
                           required />
<span asp-validation-for="Title" class="text-danger"></span>
                    <div class="char-counter">
                        <span id="titleCounter">0</span> / 100
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="Description">
                        <span class="label-icon">D</span>
                        Hizmet Açıklaması
                        <span class="required-star">*</span>
                    </label>
                    <textarea class="form-textarea" 
                              asp-for="Description" 
                              id="descriptionInput"
                              placeholder="Hizmet detaylarını ve özelliklerini açıklayın..."
                              maxlength="500"
                              required></textarea>
<span asp-validation-for="Description" class="text-danger"></span>
                    <div class="char-counter">
                        <span id="descCounter">0</span> / 500
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="ImageUrl">
                        <span class="label-icon">I</span>
                        İkon URL
                        <span class="required-star">*</span>
                    </label>
                    <input type="text" inputmode="url" 
                           class="form-input" 
                           asp-for="ImageUrl" 
                           id="imageUrlInput"
                           placeholder="https://example.com/icon.svg"
                           required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <div class="input-hint">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        SVG veya PNG formatında, şeffaf arka planlı ikon kullanın
                    </div>
                </div>

                <div class="form-group">
                    <div class="toggle-wrapper">
                        <div class="toggle-info">
                            <h4>Aktif Durum</h4>
                            <p>Hizmeti anında yayına almak için aktifleştirin</p>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" asp-for="IsStatus" id="statusToggle" checked />
<span asp-validation-for="IsStatus" class="text-danger"></span>
                            <span class="toggle-slider"></span>
                        </label>
                    </div>
                </div>

                <div class="form-actions">
                    <a asp-controller="Offer" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Hizmeti Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Sidebar -->
            <div class="sidebar">
                <!-- Preview Card -->
                <div class="preview-card">
                    <div class="preview-content">
                        <div class="preview-title">Canlı Önizleme</div>
                        <div class="preview-service-card">
                            <div class="preview-icon-container">
                                <svg id="previewIconPlaceholder" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                                </svg>
                                <img id="previewImage" src="" alt="Service Icon" />
                            </div>
                            <div class="preview-service-title" id="previewTitle">Hizmet Başlığı</div>
                            <div class="preview-service-desc" id="previewDesc">Hizmet açıklaması burada görünecek</div>
                            <div class="preview-status-badge" id="previewStatus">
                                <span class="status-dot"></span>
                                Aktif
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="info-card">
                    <div class="info-card-title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                        </svg>
                        İpuçları ve Öneriler
                    </div>
                    <ul class="tips-list">
                        <li>Başlık kısa, öz ve açıklayıcı olmalı</li>
                        <li>İkon dosyası SVG formatında ve şeffaf olmalı</li>
                        <li>Açıklama 2-3 cümlelik net bilgi içermeli</li>
                        <li>Hizmetinizi en iyi anlatan görsel seçin</li>
                        <li>Müşteri odaklı dil kullanın</li>
                    </ul>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/Offer/Edit.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


