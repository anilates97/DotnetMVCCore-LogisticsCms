@model List<ResultGetInTouchSectionDto>
@{
    ViewData["Title"] = "İletişim Bölümü Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/GetInTouchSection/Index.css" asp-append-version="true" />
}

<div class="getintouch-list-container">
    <div class="page-header">
        <div class="header-left">
            <span class="header-tag">İletişim Modülü</span>
            <h1 class="page-title">Get In Touch Bölümü</h1>
            <p class="page-subtitle">İletişim alanlarını, öne çıkan başlıkları ve içerik bloklarını yönetin.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="GetInTouchSection" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Yeni Ekle
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="24" height="24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <div class="stats-panel">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">Toplam Bölüm</div>
                <div class="stat-value">@(Model?.Count ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@(Model?.Count(x => x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Pasif</div>
                <div class="stat-value">@(Model?.Count(x => !x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Öne Çıkan Kart</div>
                <div class="stat-value">@((Model?.Count ?? 0) * 2)</div>
            </div>
        </div>
    </div>

    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Bölüm ara..." />
        </div>
        <div class="filter-toggle">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="sections-grid" id="sectionsGrid">
            @for (int i = 0; i < Model.Count; i++)
            {
                var item = Model[i];
                <div class="section-card"
                     data-id="@(i + 1)"
                     data-status="@(item.Status ? "active" : "inactive")"
                     data-title="@item.MainTitle.ToLower()">
                    <div class="card-header">
                        <div>
                            <div class="card-badge">Bölüm @((i + 1).ToString())</div>
                            <h3 class="card-title">@item.MainTitle</h3>
                        </div>
                        <div class="status-badge @(item.Status ? "active" : "inactive")">
                            @(item.Status ? "Aktif" : "Pasif")
                        </div>
                    </div>

                    <p class="card-description">@item.Description</p>

                    <div class="features-list">
                        <div class="feature-item">
                            <h4 class="feature-item-title">@item.Feature1Title</h4>
                            <p class="feature-item-desc">@item.Feature1Description</p>
                        </div>
                        <div class="feature-item">
                            <h4 class="feature-item-title">@item.Feature2Title</h4>
                            <p class="feature-item-desc">@item.Feature2Description</p>
                        </div>
                    </div>

                    <div class="card-meta">
                        <div class="meta-item">ID: @item.GetInTouchSectionId</div>
                    </div>

                    <div class="card-actions">
                        <a asp-controller="GetInTouchSection" asp-action="Edit" asp-route-id="@item.GetInTouchSectionId" class="action-btn edit">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                            </svg>
                            Düzenle
                        </a>
                        <a asp-controller="GetInTouchSection" asp-action="Delete" asp-route-id="@item.GetInTouchSectionId"
                           class="action-btn delete"
                           onclick="return confirm('Bu bölümü silmek istediğinizden emin misiniz?')">
                            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                            Sil
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <h3 class="empty-title">Henüz Bölüm Yok</h3>
            <p class="empty-text">İletişim alanını oluşturmak için ilk içeriği ekleyin.</p>
            <a asp-controller="GetInTouchSection" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                İlk Bölümü Oluştur
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/views/GetInTouchSection/Index.js" asp-append-version="true"></script>
}
