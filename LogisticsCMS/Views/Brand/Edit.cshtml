@model UpdateBrandDto
@{
    ViewData["Title"] = "UpdateBrand";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Brand/Edit.css" asp-append-version="true" />
}


<div class="brand-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="breadcrumb">
            <a asp-controller="Brand" asp-action="Index">Dashboard</a>
            <span class="breadcrumb-separator">›</span>
            <a asp-controller="Brand" asp-action="Index">Markalar</a>
            <span class="breadcrumb-separator">›</span>
            <span>Marka Güncelle</span>
        </div>
        <div class="header-content">
            <div class="header-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                </svg>
            </div>
            <div class="header-text">
                <h1>Marka Güncelle</h1>
                <p>Anlaşmalı firmalarınıza mevcut bir markayı güncelleyin</p>
            </div>
        </div>
    </div>

    <!-- Form Wrapper -->
    <form method="post" id="brandForm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="BrandId" />
<span asp-validation-for="BrandId" class="text-danger"></span>
        <div class="form-wrapper">
            <!-- Main Form -->
            <div class="form-card">
                <h2 class="form-section-title">Marka Bilgileri</h2>

                <div class="form-group">
                    <label class="form-label" asp-for="BrandName">
                        Marka Adı
                        <span class="label-badge">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                            </svg>
                            Zorunlu
                        </span>
                    </label>
                    <input type="text" 
                           class="form-input" 
                           asp-for="BrandName" 
                           id="brandNameInput"
                           placeholder="Örn: DHL, FedEx, UPS..."
                           maxlength="100"
                           required />
<span asp-validation-for="BrandName" class="text-danger"></span>
                    <div class="input-helper">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        Markanın resmi adını girin (max. 100 karakter)
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" asp-for="ImageUrl">
                        Logo URL
                        <span class="label-badge">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M8 15A7 7 0 1 1 8 1a7 7 0 0 1 0 14zm0 1A8 8 0 1 0 8 0a8 8 0 0 0 0 16z"/>
                                <path d="m8.93 6.588-2.29.287-.082.38.45.083c.294.07.352.176.288.469l-.738 3.468c-.194.897.105 1.319.808 1.319.545 0 1.178-.252 1.465-.598l.088-.416c-.2.176-.492.246-.686.246-.275 0-.375-.193-.304-.533L8.93 6.588zM9 4.5a1 1 0 1 1-2 0 1 1 0 0 1 2 0z"/>
                            </svg>
                            Zorunlu
                        </span>
                    </label>
                    <input type="text" 
                           class="form-input" 
                           asp-for="ImageUrl" 
                           id="imageUrlInput"
                           placeholder="https://example.com/logo.png"
                           inputmode="url"
                           required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                    <div class="input-helper">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        Şeffaf arka planlı PNG format önerilir (512x512 px)
                    </div>
                </div>

                <div class="form-group">
                    <div class="toggle-group">
                        <div class="toggle-label">
                            <span class="toggle-label-main">Aktif Durum</span>
                            <span class="toggle-label-sub">Markayı anında yayına almak için aktifleştirin</span>
                        </div>
                        <label class="toggle-switch">
                            <input type="checkbox" asp-for="IsStatus" id="statusToggle" />
                            <span class="toggle-slider"></span>
                        </label>
                        <span asp-validation-for="IsStatus" class="text-danger"></span>
                    </div>
                </div>

                <div class="info-box">
                    <div class="info-box-title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                        </svg>
                        İpuçları
                    </div>
                    <ul>
                        <li>Logo dosyası PNG veya SVG formatında olmalı</li>
                        <li>Şeffaf arka plan kullanın</li>
                        <li>Önerilen logo boyutu: 512x512 px veya 1024x1024 px</li>
                        <li>Logo dosya boyutu 2MB'dan küçük olmalı</li>
                    </ul>
                </div>

                <div class="form-actions">
                    <a asp-controller="Brand" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Markayı Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Sidebar -->
            <div class="preview-card">
                <div class="preview-title">
                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                    </svg>
                    Canlı Önizleme
                </div>
                <div class="preview-container">
                    <div class="preview-content">
                        <div class="preview-placeholder" id="previewPlaceholder">
                            <div class="preview-icon-wrapper">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                            </div>
                            <p class="preview-text">Marka bilgilerini girdikçe önizleme burada görünecek</p>
                            <p class="preview-hint">Logo ve isim güncelleniyor...</p>
                        </div>
                        <div class="brand-preview" id="brandPreview">
                            <img src="" alt="Brand Logo" id="previewLogo" class="preview-logo" />
                            <div class="preview-brand-name" id="previewName">Marka Adı</div>
                            <span class="preview-status active" id="previewStatus">
                                <span class="preview-status-dot"></span>
                                Aktif
                            </span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/Brand/Edit.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


