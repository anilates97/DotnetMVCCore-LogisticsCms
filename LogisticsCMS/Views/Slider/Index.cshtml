@model List<ResultSliderDto>

@{
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Slider/Index.css" asp-append-version="true" />
}


<div class="slider-list-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-content">
            <div class="header-text">
                <h1 class="page-title">Slider Yönetimi</h1>
                <p class="page-subtitle">Tüm slider'ları görüntüleyin, düzenleyin ve yönetin</p>
            </div>
        </div>
        <div class="header-actions">
            <a asp-controller="Slider" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Yeni Slider Ekle
            </a>
            <button class="btn btn-icon" title="Yenile">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Stats -->
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-icon primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Toplam Slider</div>
                <div class="stat-value">@Model.Count</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon success">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@Model.Count</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon warning">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Görüntüleme</div>
                <div class="stat-value">@(Model.Count * 1247)</div>
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-icon info">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
            <div class="stat-content">
                <div class="stat-label">Son Güncelleme</div>
                <div class="stat-value" style="font-size: 14px;">Bugün</div>
            </div>
        </div>
    </div>

    <!-- Search and Filter -->
    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Slider ara..." />
        </div>
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    <!-- Table -->
    <div class="table-card">
        <div class="table-wrapper">
            @if (Model != null && Model.Any())
            {
                <table class="slider-table">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Slider Bilgisi</th>
                            <th>Açıklama</th>
                            <th>İşlemler</th>
                        </tr>
                    </thead>
                    <tbody id="sliderTableBody">
                        @for (int i = 0; i < Model.Count; i++)
                        {
                            var item = Model[i];
                            <tr data-slider-id="@item.SliderId">
                                <td>
                                    <span style="font-family: 'Space Mono', monospace; font-weight: 600; color: var(--text-muted);">
                                        @(i + 1).
                                    </span>
                                </td>
                                <td>
                                    <div class="slider-preview">
                                        <img src="@item.ImageUrl" alt="@item.Title" class="slider-image" />
                                        <div class="slider-info">
                                            <div class="slider-title">@item.Title</div>
                                            <div class="slider-subtitle">@item.SubTitle</div>
                                        </div>
                                    </div>
                                </td>
                                <td>
                                    <div class="slider-description text-truncate">
                                        @item.Description
                                    </div>
                                </td>
                                <td>
                                    <div class="action-buttons">
                                        <a asp-controller="Slider" asp-action="Edit" asp-route-id="@item.SliderId" class="action-btn edit" title="Düzenle">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                            </svg>
                                        </a>
                                        <a asp-controller="Slider" asp-action="Delete" asp-route-id="@item.SliderId" class="action-btn delete" title="Sil" onclick="return confirm('Bu slider\'ı silmek istediğinizden emin misiniz?')">
                                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                            </svg>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="empty-state">
                    <div class="empty-icon">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                    </div>
                    <h3 class="empty-title">Henüz Slider Yok</h3>
                    <p class="empty-text">Başlamak için ilk slider'ınızı oluşturun</p>
                    <a asp-controller="Slider" asp-action="Create" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="18" height="18">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                        </svg>
                        İlk Slider'ı Oluştur
                    </a>
                </div>
            }
        </div>

        @if (Model != null && Model.Any())
        {
            <div class="pagination">
                <button class="page-btn" disabled>
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                    </svg>
                </button>
                <button class="page-btn active">1</button>
                <button class="page-btn">2</button>
                <button class="page-btn">3</button>
                <button class="page-btn">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                    </svg>
                </button>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/js/views/Slider/Index.js" asp-append-version="true"></script>
}



