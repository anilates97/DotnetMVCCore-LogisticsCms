@model CreateSliderDto
@{
    ViewData["Title"] = "CreateSlider";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Slider/Create.css" asp-append-version="true" />
}


<div class="create-slider-container">
    <div class="page-header">
        <div class="page-header-content">
            <h1 class="page-title">Yeni Slider Oluştur</h1>
            <p class="page-subtitle">Ana sayfada gösterilecek yeni bir slider ekleyin</p>
        </div>
    </div>

    <form method="post" id="sliderForm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="form-card">
            <div class="form-content">
                <div class="form-grid">
                    <div class="form-group">
                        <label class="form-label" asp-for="Title">
                            <span class="form-label-icon">T</span>
                            Başlık
                        </label>
                        <input type="text" 
                               class="form-input" 
                               asp-for="Title" 
                               placeholder="Slider başlığını girin..."
                               maxlength="100"
                               required />
<span asp-validation-for="Title" class="text-danger"></span>
                        <div class="char-counter">
                            <span id="titleCounter">0</span> / 100
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="SubTitle">
                            <span class="form-label-icon">S</span>
                            Alt Başlık
                        </label>
                        <input type="text" 
                               class="form-input" 
                               asp-for="SubTitle" 
                               placeholder="Alt başlık girin..."
                               maxlength="150" />
<span asp-validation-for="SubTitle" class="text-danger"></span>
                        <div class="char-counter">
                            <span id="subtitleCounter">0</span> / 150
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label class="form-label" asp-for="Description">
                            <span class="form-label-icon">D</span>
                            Açıklama
                        </label>
                        <textarea class="form-textarea" 
                                  asp-for="Description" 
                                  placeholder="Slider açıklamasını girin..."
                                  maxlength="500"></textarea>
<span asp-validation-for="Description" class="text-danger"></span>
                        <div class="char-counter">
                            <span id="descCounter">0</span> / 500
                        </div>
                    </div>

                    <div class="form-group full-width">
                        <label class="form-label" asp-for="ImageUrl">
                            <span class="form-label-icon">I</span>
                            Görsel URL
                        </label>
                        <input type="text" inputmode="url" 
                               class="form-input" 
                               asp-for="ImageUrl" 
                               id="imageUrlInput"
                               placeholder="https://example.com/image.jpg"
                               required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                    </div>
                </div>

                <div class="image-preview-section" id="imagePreviewSection">
                    <div class="preview-placeholder" id="previewPlaceholder">
                        <div class="preview-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <p class="preview-text">Görsel URL'si girildiğinde önizleme burada görünecek</p>
                        <p class="preview-hint">Önerilen boyut: 1920x1080 px</p>
                    </div>
                    <img src="" alt="Slider Preview" class="preview-image" id="previewImage" />
                </div>
            </div>

            <div class="form-footer">
                <div class="form-tips">
                    <svg class="tips-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <div class="tips-content">
                        <h4>İpuçları</h4>
                        <ul>
                            <li>Başlık kısa ve etkili olmalı (maks. 100 karakter)</li>
                            <li>Görsel yüksek kaliteli ve 1920x1080 px boyutunda olmalı</li>
                            <li>Açıklama, ziyaretçilere net bir mesaj vermeli</li>
                        </ul>
                    </div>
                </div>
            </div>

            <div class="form-actions">
                <a asp-controller="Slider" asp-action="Index" class="btn btn-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                    İptal
                </a>
                <button type="submit" class="btn btn-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    Slider Oluştur
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/Slider/Create.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


