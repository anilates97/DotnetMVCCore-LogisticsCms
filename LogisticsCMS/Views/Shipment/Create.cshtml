@model CreateShipmentDto
@{
    ViewData["Title"] = "CreateShipment";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/Shipment/Create.css" asp-append-version="true" />
}


<div class="shipment-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-top">
            <div class="breadcrumb">
                <a href="/Dashboard">
                    <i class="bi bi-house-door"></i> Ana Sayfa
                </a>
                <i class="bi bi-chevron-right"></i>
                <a asp-controller="Shipment" asp-action="Index">Gönderiler</a>
                <i class="bi bi-chevron-right"></i>
                <span>Yeni Gönderi</span>
            </div>
            <div class="header-actions">
                <button class="btn-icon" title="Yardım">
                    <i class="bi bi-question-circle"></i>
                </button>
                <button class="btn-icon" title="Ayarlar">
                    <i class="bi bi-gear"></i>
                </button>
            </div>
        </div>
        <h1 class="page-title">
            <div class="title-icon">
                <i class="bi bi-box-seam"></i>
            </div>
            Yeni Kargo Gönderi Oluştur
        </h1>
        <p class="page-subtitle">Gönderi bilgilerini girerek yeni bir kargo kaydı oluşturun</p>
    </div>

    <!-- Main Grid -->
    <form method="post" id="shipmentForm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <div class="main-grid">
            <!-- Form Column -->
            <div class="form-column">
                <!-- Tracking Info Section -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">1</div>
                        <div class="section-title">Takip Bilgileri</div>
                    </div>

                    <div class="form-grid full">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-upc-scan label-icon"></i>
                                Takip Numarası
                                <span class="label-required">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-input tracking-input" 
                                asp-for="TrackingNumber"
                                id="trackingInput"
                                placeholder="TRK-" 
                                maxlength="50"
                                required 
                            />
<span asp-validation-for="TrackingNumber" class="text-danger"></span>
                            <div class="input-hint">
                                <i class="bi bi-info-circle"></i>
                                Otomatik oluşturulmaktadır (TRK-XXXXXXXX)
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Sender & Receiver Info -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">2</div>
                        <div class="section-title">Gönderici ve Alıcı Bilgileri</div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-person label-icon"></i>
                                Gönderici Adı
                                <span class="label-required">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-input" 
                                asp-for="SenderName"
                                id="senderInput"
                                placeholder="Örn: Ahmet Yılmaz" 
                                maxlength="100"
                                required 
                            />
<span asp-validation-for="SenderName" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-person-check label-icon"></i>
                                Alıcı Adı
                                <span class="label-required">*</span>
                            </label>
                            <input 
                                type="text" 
                                class="form-input" 
                                asp-for="ReceiverName"
                                id="receiverInput"
                                placeholder="Örn: Mehmet Demir" 
                                maxlength="100"
                                required 
                            />
<span asp-validation-for="ReceiverName" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="info-card">
                        <i class="bi bi-shield-check info-icon"></i>
                        <div class="info-content">
                            <div class="info-title">Güvenlik Notu</div>
                            <div class="info-text">
                                Gönderici ve alıcı bilgileri gizlilik politikası kapsamında korunmaktadır.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Origin Location -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">3</div>
                        <div class="section-title">Çıkış Lokasyonu</div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-geo-alt label-icon"></i>
                                Çıkış Şehri
                                <span class="label-required">*</span>
                            </label>
                            <input
                                type="text"
                                class="form-input"
                                asp-for="OriginCity"
                                id="originCityInput"
                                placeholder="Örn: İstanbul"
                                maxlength="100"
                                required
                            />
<span asp-validation-for="OriginCity" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-pin-map label-icon"></i>
                                Çıkış İlçesi
                                <span class="label-required">*</span>
                            </label>
                            <input
                                type="text"
                                class="form-input"
                                asp-for="OriginDistrict"
                                id="originDistrictInput"
                                placeholder="Örn: Kadıköy"
                                maxlength="100"
                                required
                            />
<span asp-validation-for="OriginDistrict" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Destination Location -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">4</div>
                        <div class="section-title">Varış Lokasyonu</div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-geo-alt label-icon"></i>
                                Varış Şehri
                                <span class="label-required">*</span>
                            </label>
                            <input
                                type="text"
                                class="form-input"
                                asp-for="DestinationCity"
                                id="destinationCityInput"
                                placeholder="Örn: Ankara"
                                maxlength="100"
                                required
                            />
<span asp-validation-for="DestinationCity" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-pin-map label-icon"></i>
                                Varış İlçesi
                                <span class="label-required">*</span>
                            </label>
                            <input
                                type="text"
                                class="form-input"
                                asp-for="DestinationDistrict"
                                id="destinationDistrictInput"
                                placeholder="Örn: Çankaya"
                                maxlength="100"
                                required
                            />
<span asp-validation-for="DestinationDistrict" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Address Info -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">5</div>
                        <div class="section-title">Adres Bilgisi</div>
                    </div>

                    <div class="form-grid full">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-mailbox label-icon"></i>
                                Detaylı Adres
                                <span class="label-required">*</span>
                            </label>
                            <textarea 
                                class="form-textarea" 
                                asp-for="Address"
                                id="addressInput"
                                rows="4"
                                placeholder="Mahalle, sokak, bina no, daire no vb. detaylı adres bilgisi..."
                                maxlength="500"
                                required
                            ></textarea>
<span asp-validation-for="Address" class="text-danger"></span>
                            <div class="input-hint">
                                <i class="bi bi-info-circle"></i>
                                Teslimat için detaylı adres bilgisi giriniz
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Info -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">6</div>
                        <div class="section-title">Durum Bilgileri</div>
                    </div>

                    <div class="form-grid">
                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-calendar-event label-icon"></i>
                                Oluşturulma Tarihi
                                <span class="label-required">*</span>
                            </label>
                            <input 
                                type="datetime-local" 
                                class="form-input" 
                                asp-for="CreatedDate"
                                id="dateInput"
                                required 
                            />
<span asp-validation-for="CreatedDate" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label class="form-label">
                                <i class="bi bi-flag label-icon"></i>
                                Güncel Durum
                                <span class="label-required">*</span>
                            </label>
                            <select 
                                class="form-select" 
                                asp-for="CurrentStatus"
                                id="statusInput"
                                required
                            >
                                <option value="">Durum Seçiniz</option>
                                <option value="Gönderi Alındı">Gönderi Alındı</option>
                                <option value="Transfer Merkezinde">Transfer Merkezinde</option>
                                <option value="Yolda">Yolda</option>
                                <option value="Dağıtımda">Dağıtımda</option>
                                <option value="Teslim Edildi">Teslim Edildi</option>
                            </select>
<span asp-validation-for="CurrentStatus" class="text-danger"></span>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-controller="Shipment" asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-x-circle"></i>
                        İptal
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-check-circle"></i>
                        Gönderiyi Kaydet
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-card">
                    <div class="preview-header">
                        <div class="preview-label">
                            <i class="bi bi-eye"></i> Canlı Önizleme
                        </div>
                    </div>

                    <div class="shipment-card">
                        <div class="tracking-badge">TRACKING NUMBER</div>
                        <div class="tracking-number-display" id="previewTracking">TRK-XXXXXXXX</div>
                        <div class="route-display">
                            <div class="route-item">
                                <i class="bi bi-geo-alt-fill"></i>
                                <span id="previewOriginFull">Çıkış: Şehir / İlçe</span>
                            </div>
                            <div class="route-item">
                                <i class="bi bi-arrow-down"></i>
                            </div>
                            <div class="route-item">
                                <i class="bi bi-pin-map-fill"></i>
                                <span id="previewDestinationFull">Varış: Şehir / İlçe</span>
                            </div>
                        </div>
                    </div>

                    <div class="preview-details">
                        <div class="preview-item">
                            <span class="preview-item-label">Gönderici</span>
                            <span class="preview-item-value" id="previewSender">-</span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-item-label">Alıcı</span>
                            <span class="preview-item-value" id="previewReceiver">-</span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-item-label">Adres</span>
                            <span class="preview-item-value" id="previewAddress" style="font-size: 11px; max-width: 200px;">-</span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-item-label">Oluşturma</span>
                            <span class="preview-item-value" id="previewDate">-</span>
                        </div>
                        <div class="preview-item">
                            <span class="preview-item-label">Durum</span>
                            <span class="status-preview" id="previewStatus">Bekliyor</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/Shipment/Create.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


