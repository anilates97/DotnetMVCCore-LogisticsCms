@model List<ResultProjectSectionDto>
@{
    ViewData["Title"] = "Proje Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/ProjectSection/Index.css" asp-append-version="true" />
}


<div class="project-list-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-left">
            <div class="breadcrumb">
                <span class="breadcrumb-item">
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                    </svg>
                    Ana Sayfa
                </span>
                <span class="breadcrumb-separator">/</span>
                <span class="breadcrumb-item">Projeler</span>
            </div>
            <h1 class="page-title">Proje Portföyü</h1>
            <p class="page-subtitle">Tüm tamamlanmış projelerinizi görüntüleyin ve yönetin</p>
        </div>
        <div class="header-actions">
            <a asp-controller="ProjectSection" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                Yeni Proje
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <!-- Stats Bar -->
    <div class="stats-bar">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-label">Toplam Proje</div>
                <div class="stat-value">@(Model?.Count ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Aktif</div>
                <div class="stat-value">@(Model?.Count(x => x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Pasif</div>
                <div class="stat-value">@(Model?.Count(x => !x.Status) ?? 0)</div>
            </div>
            <div class="stat-item">
                <div class="stat-label">Bu Ay</div>
                <div class="stat-value">@((Model?.Count ?? 0) > 0 ? Math.Min(Model?.Count ?? 0, 3) : 0)</div>
            </div>
        </div>
    </div>

    <!-- Control Bar -->
    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="Proje ara..." />
        </div>
        <div class="filter-group">
            <button class="filter-btn active" data-filter="all">Tümü</button>
            <button class="filter-btn" data-filter="active">Aktif</button>
            <button class="filter-btn" data-filter="inactive">Pasif</button>
        </div>
    </div>

    <!-- Projects Grid -->
    @if (Model != null && Model.Any())
    {
        <div class="projects-grid" id="projectsGrid">
            @foreach (var project in Model)
            {
                <div class="project-card" 
                     data-status="@(project.Status ? "active" : "inactive")"
                     data-title="@project.Title.ToLower()">
                    <div class="card-image">
                        <img src="@project.ImageUrl" alt="@project.Title" />
                        <div class="status-indicator @(project.Status ? "active" : "inactive")">
                            @(project.Status ? "Aktif" : "Pasif")
                        </div>
                    </div>
                    <div class="card-content">
                        <h3 class="project-title">@project.Title</h3>
                        <p class="project-description">@project.Description</p>
                        
                        <div class="card-footer">
                            <div class="meta-info">
                                ID: @project.ProjectSectionId.Substring(0, 8)
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-controller="ProjectSection" asp-action="Edit" asp-route-id="@project.ProjectSectionId" class="action-btn edit">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Düzenle
                            </a>
                            <a asp-controller="ProjectSection" asp-action="Delete" asp-route-id="@project.ProjectSectionId" 
                               class="action-btn delete" 
                               onclick="return confirm('Bu projeyi silmek istediğinizden emin misiniz?')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Pagination -->
        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
                </svg>
            </div>
            <h3 class="empty-title">Henüz Proje Yok</h3>
            <p class="empty-text">Tamamladığınız projeleri ekleyerek portföyünüzü oluşturmaya başlayın</p>
            <a asp-controller="ProjectSection" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="16" height="16">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                İlk Projeyi Ekle
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/views/ProjectSection/Index.js" asp-append-version="true"></script>
}



