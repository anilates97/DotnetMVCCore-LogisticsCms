@model CreateProjectSectionDto
@{
    ViewData["Title"] = "CreateProjectSection";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/ProjectSection/Create.css" asp-append-version="true" />
}


<div class="project-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="breadcrumb">
            <span class="breadcrumb-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                Ana Sayfa
            </span>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-item">Projeler</span>
            <span class="breadcrumb-separator">/</span>
            <span class="breadcrumb-item">Yeni Proje</span>
        </div>
        <h1 class="page-title">Yeni Proje Oluştur</h1>
        <p class="page-subtitle">Tamamladığınız projeleri portföyünüze ekleyin ve başarılarınızı sergileyin</p>
    </div>

    <!-- Split Layout -->
    <form method="post" id="projectForm" asp-controller="ProjectSection" asp-action="Create">
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <!-- Basic Info Card -->
                <div class="form-card">
                    <div class="card-header">
                        <div class="card-number">1</div>
                        <h2 class="card-title">Temel Bilgiler</h2>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Title">
                            Proje Başlığı <span class="label-required">*</span>
                        </label>
                        <input type="text" 
                               class="form-input" 
                               asp-for="Title" 
                               id="titleInput"
                               placeholder="Örn: Hava Kargo Taşımacılığı"
                               maxlength="100"
                               required />
<span asp-validation-for="Title" class="text-danger"></span>
                        <div class="input-meta">
                            <span class="input-hint">Açık ve profesyonel bir başlık kullanın</span>
                            <span class="char-counter">
                                <span id="titleCounter">0</span>/100
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Description">
                            Proje Açıklaması <span class="label-required">*</span>
                        </label>
                        <textarea class="form-textarea" 
                                  asp-for="Description" 
                                  id="descriptionInput"
                                  placeholder="Projenin detaylarını, kapsamını ve başarılarını açıklayın..."
                                  maxlength="300"
                                  required></textarea>
<span asp-validation-for="Description" class="text-danger"></span>
                        <div class="input-meta">
                            <span class="input-hint">Projenin öne çıkan özelliklerini vurgulayın</span>
                            <span class="char-counter">
                                <span id="descCounter">0</span>/300
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Media Card -->
                <div class="form-card">
                    <div class="card-header">
                        <div class="card-number">2</div>
                        <h2 class="card-title">Görsel</h2>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ImageUrl">
                            Görsel URL <span class="label-required">*</span>
                        </label>
                        <input type="text" inputmode="url" 
                               class="form-input" 
                               asp-for="ImageUrl" 
                               id="imageUrlInput"
                               placeholder="https://example.com/project-image.jpg"
                               required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <div class="input-meta">
                            <span class="input-hint">1920x1080 veya üzeri çözünürlük önerilir</span>
                        </div>
                    </div>

                    <div class="info-banner">
                        <svg class="info-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <div class="info-content">
                            <div class="info-title">Görsel İpuçları</div>
                            <div class="info-text">
                                Profesyonel, yüksek kaliteli ve projeyi en iyi temsil eden görseller kullanın. 
                                Görseller 16:9 oranında olmalıdır.
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Status Card -->
                <div class="form-card">
                    <div class="card-header">
                        <div class="card-number">3</div>
                        <h2 class="card-title">Yayın Ayarları</h2>
                    </div>

                    <div class="form-group">
                        <div class="status-toggle-wrapper">
                            <div class="status-label">
                                <h4>Durum</h4>
                                <p>Projeyi anında yayınla</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" asp-for="Status" id="statusToggle" checked />
<span asp-validation-for="Status" class="text-danger"></span>
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-controller="ProjectSection" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        İptal
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        Projeyi Kaydet
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-header">
                        <div class="preview-label">Canlı Önizleme</div>
                    </div>
                    <div class="preview-content">
                        <div class="project-card-preview">
                            <div class="preview-image-container">
                                <img src="" id="previewImage" alt="Preview" />
                                <div class="image-placeholder" id="imagePlaceholder">
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                    <div class="image-placeholder-text">Proje Görseli</div>
                                </div>
                            </div>
                            <div class="preview-card-content">
                                <h3 class="preview-title" id="previewTitle">Proje Başlığı</h3>
                                <p class="preview-description" id="previewDescription">Proje açıklaması burada görünecek...</p>
                                <a href="#" class="preview-button">
                                    <span>Detayları Gör</span>
                                    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                                    </svg>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/ProjectSection/Create.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


