@model List<ResultAboutDto>
@{
    ViewData["Title"] = "Hakkımızda Listesi";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/About/Index.css" asp-append-version="true" />
}

<div class="about-list-container">
    <div class="page-header">
        <div class="header-left">
            <div class="header-top">
                <div class="header-line"></div>
                <span class="header-label">HAKKIMIZDA YÖNETİMİ</span>
            </div>
            <h1 class="page-title">
                <span class="title-highlight">Kurumsal</span> İçerikler
            </h1>
            <p class="page-subtitle">Firmanızın hikayesini, değerlerini ve kurumsal anlatımını yönetin.</p>
        </div>
        <div class="header-actions">
            <a asp-controller="About" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>Yeni Ekle</span>
            </a>
            <button class="btn btn-icon" title="Yenile" onclick="location.reload()">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="22" height="22">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
            </button>
        </div>
    </div>

    <div class="stats-bar">
        <div class="stats-grid">
            <div class="stat-item">
                <div class="stat-value">@Model.Count</div>
                <div class="stat-label">Toplam İçerik</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@(Model.Count * 3284)</div>
                <div class="stat-label">Görüntülenme</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">@(Model.Any() ? Model.First().Title.Length : 0)</div>
                <div class="stat-label">Ort. Başlık Uzunluğu</div>
            </div>
            <div class="stat-item">
                <div class="stat-value">%@(Model.Any() ? 98 : 0)</div>
                <div class="stat-label">Okuma Oranı</div>
            </div>
        </div>
    </div>

    <div class="control-bar">
        <div class="search-box">
            <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
            </svg>
            <input type="text" class="search-input" id="searchInput" placeholder="İçerik ara..." />
        </div>
        <div class="view-toggle">
            <button class="view-btn active" data-view="grid" title="Grid Görünüm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
                </svg>
            </button>
            <button class="view-btn" data-view="list" title="Liste Görünüm">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
                </svg>
            </button>
        </div>
    </div>

    @if (Model != null && Model.Any())
    {
        <div class="content-grid" id="contentGrid">
            @foreach (var about in Model)
            {
                <div class="about-card" data-title="@about.Title.ToLower()">
                    <div class="card-image-wrapper">
                        <img src="@about.ImageUrl" alt="@about.Title" class="card-image" />
                        <div class="card-badge">HAKKIMIZDA</div>
                    </div>
                    <div class="card-content">
                        <h3 class="card-title">@about.Title</h3>
                        <p class="card-description">@about.Description</p>

                        <div class="card-meta">
                            <div class="card-meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                </svg>
                                ID: @about.AboutId.Substring(0, 8)
                            </div>
                            <div class="card-meta-item">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                                @((about.Description.Length * 28)) Görüntüleme
                            </div>
                        </div>

                        <div class="card-actions">
                            <a asp-controller="About" asp-action="Edit" asp-route-id="@about.AboutId" class="action-btn edit">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Düzenle
                            </a>
                            <a asp-controller="About" asp-action="Delete" asp-route-id="@about.AboutId" class="action-btn delete" onclick="return confirm('Bu içeriği silmek istediğinizden emin misiniz?')">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                </svg>
                                Sil
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="pagination">
            <button class="page-btn" disabled>
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <button class="page-btn active">1</button>
            <button class="page-btn">2</button>
            <button class="page-btn">3</button>
            <button class="page-btn">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
                </svg>
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
                </svg>
            </div>
            <h3 class="empty-title">Henüz İçerik Yok</h3>
            <p class="empty-text">Firmanızın hikayesini ve değerlerini paylaşmak için ilk hakkımızda içeriğinizi oluşturun.</p>
            <a asp-controller="About" asp-action="Create" class="btn btn-primary">
                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" width="20" height="20">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>İlk İçeriği Oluştur</span>
            </a>
        </div>
    }
</div>

@section Scripts {
    <script src="~/js/views/About/Index.js" asp-append-version="true"></script>
}
