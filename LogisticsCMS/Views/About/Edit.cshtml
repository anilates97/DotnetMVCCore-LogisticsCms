@model UpdateAboutDto
@{
    ViewData["Title"] = "UpdateAbout";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/About/Edit.css" asp-append-version="true" />
}


<div class="about-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-top">
            <div class="header-line"></div>
            <span class="header-label">HAKKIMIZDA İÇERİĞİ</span>
        </div>
        <h1 class="page-title">
            <span class="title-highlight">Kurumsal</span> Hikayenizi Anlatın
        </h1>
        <p class="page-subtitle">
            Firmanızın değerlerini, vizyonunu ve hikayesini müşterilerinizle paylaşmak için hakkımızda içeriği oluşturun.
        </p>
    </div>

    <!-- Split Layout -->
    <form method="post" id="aboutForm">
        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>
        <input type="hidden" asp-for="AboutId" />
<span asp-validation-for="AboutId" class="text-danger"></span>
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <!-- Section 1: Content -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">01</div>
                        <h2 class="section-title">İçerik Bilgileri</h2>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Başlık</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8"/>
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <input type="text" 
                               class="form-input" 
                               asp-for="Title" 
                               id="titleInput"
                               placeholder="Örn: Bizim Hikayemiz, Kimiz Biz, Misyonumuz..."
                               maxlength="150"
                               required />
<span asp-validation-for="Title" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                                Kısa ve etkileyici bir başlık kullanın
                            </div>
                            <span class="char-count">
                                <span id="titleCounter">0</span> / 150
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Açıklama</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8"/>
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <textarea class="form-textarea" 
                                  asp-for="Description" 
                                  id="descriptionInput"
                                  placeholder="Firmanızın hikayesini, değerlerini ve vizyonunu buraya yazın..."
                                  maxlength="1000"
                                  required></textarea>
<span asp-validation-for="Description" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Samimi ve içten bir dil kullanın
                            </div>
                            <span class="char-count">
                                <span id="descCounter">0</span> / 1000
                            </span>
                        </div>
                    </div>
                </div>

                <!-- Section 2: Image -->
                <div class="form-section">
                    <div class="section-header">
                        <div class="section-number">02</div>
                        <h2 class="section-title">Görsel Ekle</h2>
                    </div>

                    <div class="form-group">
                        <div class="form-label">
                            <span class="label-text">Görsel URL</span>
                            <span class="label-badge">
                                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" fill="currentColor" viewBox="0 0 16 16">
                                    <circle cx="8" cy="8" r="8"/>
                                </svg>
                                Zorunlu
                            </span>
                        </div>
                        <input type="text" inputmode="url" 
                               class="form-input" 
                               asp-for="ImageUrl" 
                               id="imageUrlInput"
                               placeholder="https://example.com/image.jpg"
                               required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                1920x1080 px veya daha büyük önerilir
                            </div>
                        </div>
                    </div>

                    <div class="image-upload-area" onclick="document.getElementById('imageUrlInput').focus()">
                        <div class="upload-icon-wrapper">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <p class="upload-text">Görsel URL'sini yukarıya girin</p>
                        <p class="upload-hint">Yüksek kaliteli ve profesyonel görseller kullanın</p>
                    </div>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-controller="About" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-content">
                        <div class="preview-label">
                            <span class="preview-label-dot"></span>
                            CANLI ÖNİZLEME
                        </div>
                        <div class="preview-card">
                            <div class="preview-image-container">
                                <img src="" alt="Preview" id="previewImage" />
                                <div class="preview-placeholder" id="previewPlaceholder">
                                    <div class="preview-placeholder-icon">
                                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                        </svg>
                                    </div>
                                    <p class="preview-placeholder-text">Görsel burada görünecek</p>
                                </div>
                            </div>
                            <h3 class="preview-title" id="previewTitle">Başlık Giriniz</h3>
                            <p class="preview-description" id="previewDescription">Açıklama burada görünecek...</p>
                        </div>
                    </div>
                </div>

                <!-- Info Card -->
                <div class="info-card">
                    <div class="info-card-header">
                        <div class="info-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                            </svg>
                        </div>
                        <h4 class="info-card-title">İpuçları</h4>
                    </div>
                    <ul class="info-list">
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Hikayenizi samimi ve içten anlatın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Değerlerinizi ve misyonunuzu vurgulayın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Profesyonel ve yüksek çözünürlüklü görsel kullanın
                        </li>
                        <li>
                            <div class="info-list-icon">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            Açık ve anlaşılır bir dil tercih edin
                        </li>
                    </ul>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/About/Edit.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


