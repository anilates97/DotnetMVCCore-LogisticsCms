@model CreateHowItWorkDto
@{
    ViewData["Title"] = "CreateHowItWork";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

@section Styles {
    <link rel="stylesheet" href="~/css/views/HowItWork/Create.css" asp-append-version="true" />
}


<div class="howitwork-create-container">
    <!-- Header -->
    <div class="page-header">
        <div class="header-decoration">
            <div class="decoration-circle"></div>
            <div class="decoration-circle"></div>
            <div class="decoration-circle"></div>
            <div class="decoration-circle"></div>
        </div>
        <h1 class="page-title">Nasıl Çalışır Adımı Ekle</h1>
        <p class="page-subtitle">Müşterilerinize süreç adımlarını göstermek için yeni bir adım oluşturun</p>
    </div>

    <!-- Split Layout -->
    <form method="post" id="howItWorkForm" asp-controller="HowItWork" asp-action="Create">
        <div class="split-layout">
            <!-- Form Column -->
            <div class="form-column">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <!-- Main Info Card -->
                <div class="form-card">
                    <h2 class="card-title">
                        <div class="card-icon">
                            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                        </div>
                        Adım Bilgileri
                    </h2>

                    <div class="form-group">
                        <label class="form-label" asp-for="Title">
                            Başlık <span class="label-required">*</span>
                        </label>
                        <input type="text" 
                               class="form-input" 
                               asp-for="Title" 
                               id="titleInput"
                               placeholder="Örn: Müşteri Sipariş Verir"
                               maxlength="100"
                               required />
<span asp-validation-for="Title" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                                </svg>
                                Kısa ve net bir başlık yazın
                            </div>
                            <span class="char-counter">
                                <span id="titleCounter">0</span>/100
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="Description">
                            Açıklama <span class="label-required">*</span>
                        </label>
                        <textarea class="form-textarea" 
                                  asp-for="Description" 
                                  id="descriptionInput"
                                  placeholder="Bu adımın detaylı açıklamasını yazın..."
                                  maxlength="300"
                                  required></textarea>
<span asp-validation-for="Description" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                </svg>
                                Anlaşılır ve bilgilendirici olsun
                            </div>
                            <span class="char-counter">
                                <span id="descCounter">0</span>/300
                            </span>
                        </div>
                    </div>

                    <div class="form-group">
                        <label class="form-label" asp-for="ImageUrl">
                            İkon URL <span class="label-required">*</span>
                        </label>
                        <input type="text" inputmode="url" 
                               class="form-input" 
                               asp-for="ImageUrl" 
                               id="iconUrlInput"
                               placeholder="https://example.com/icon.svg"
                               required />
<span asp-validation-for="ImageUrl" class="text-danger"></span>
                        <div class="input-meta">
                            <div class="input-hint">
                                <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                </svg>
                                SVG veya PNG formatında icon
                            </div>
                        </div>
                    </div>

                    <div class="form-group">
                        <div class="status-wrapper">
                            <div class="status-label">
                                <h4>Aktif Durum</h4>
                                <p>Adımı anında göster</p>
                            </div>
                            <label class="toggle-switch">
                                <input type="checkbox" asp-for="Status" id="statusToggle" checked />
<span asp-validation-for="Status" class="text-danger"></span>
                                <span class="toggle-slider"></span>
                            </label>
                        </div>
                    </div>
                </div>

                <!-- Info Box -->
                <div class="info-box">
                    <h3 class="info-box-title">
                        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        İpuçları
                    </h3>
                    <ul class="info-list">
                        <li>Başlıklar eylem odaklı olmalı (Örn: "Müşteri Sipariş Verir")</li>
                        <li>Açıklama net ve anlaşılır olmalı</li>
                        <li>İkonlar adımı görsel olarak temsil etmeli</li>
                        <li>Tüm adımlar mantıksal bir sıra izlemeli</li>
                    </ul>
                </div>

                <!-- Actions -->
                <div class="form-actions">
                    <a asp-controller="HowItWork" asp-action="Index" class="btn btn-secondary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span>İptal</span>
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span>Adımı Kaydet</span>
                    </button>
                </div>
            </div>

            <!-- Preview Column -->
            <div class="preview-column">
                <div class="preview-wrapper">
                    <div class="preview-content">
                        <div class="preview-label">Canlı Önizleme</div>
                        <div class="timeline-preview">
                            <div class="timeline-step">
                                <div class="step-icon-wrapper">
                                    <img src="" id="previewIcon1" style="display:none;" />
                                    <svg class="step-icon-placeholder" id="iconPlaceholder1" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                                    </svg>
                                </div>
                                <div class="step-content">
                                    <h3 class="step-title" id="previewTitle">Başlık Giriniz</h3>
                                    <p class="step-description" id="previewDescription">Açıklama burada görünecek...</p>
                                </div>
                            </div>

                            <div class="timeline-step">
                                <div class="step-icon-wrapper">
                                    <svg class="step-icon-placeholder" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                                    </svg>
                                </div>
                                <div class="step-content">
                                    <h3 class="step-title">Ödeme Başarılı</h3>
                                    <p class="step-description">Müşteri güvenli ödeme işlemini tamamlar</p>
                                </div>
                            </div>

                            <div class="timeline-step">
                                <div class="step-icon-wrapper">
                                    <svg class="step-icon-placeholder" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 8h14M5 8a2 2 0 110-4h14a2 2 0 110 4M5 8v10a2 2 0 002 2h10a2 2 0 002-2V8m-9 4h4" />
                                    </svg>
                                </div>
                                <div class="step-content">
                                    <h3 class="step-title">Teslimat</h3>
                                    <p class="step-description">Paket adrese güvenle teslim edilir</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <script src="~/js/views/HowItWork/Create.js" asp-append-version="true"></script>
    <partial name="_ValidationScriptsPartial" />
}


